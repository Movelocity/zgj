PORT=8890
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_MS=180000
UPLOAD_DIR=./data/uploads

# Optional. If set, requests must use Authorization: Bearer <token>.
LANGCHAIN_SERVICE_TOKEN=

# ChromaDB vector matching. Start Chroma separately, e.g.:
# chroma run --path ./data/chroma --host 127.0.0.1 --port 8000
CHROMA_URL=http://127.0.0.1:8000
CHROMA_COLLECTION=job_opportunities
EMBEDDING_MODEL=Xenova/multilingual-e5-small
