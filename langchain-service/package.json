{
  "name": "zgj-langchain-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "npm run build && node dist/src/server.js",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:doc": "tsx scripts/smoke-doc.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^1.1.0",
    "@langchain/deepseek": "^1.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "mammoth": "^1.8.0",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.0",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
